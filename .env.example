# ── DashClub Portfolio — variables d'environnement ──────────────────────────
# Copier ce fichier en .env.local et remplir les valeurs

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_19=
STRIPE_PRICE_49=
STRIPE_PRICE_99=
STRIPE_PRICE_DOMAIN=
STRIPE_WEBHOOK_SECRET=

# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
INSCRIPTION_NOTIFICATION_EMAIL=
INSCRIPTION_EMAIL_MODE=nanocorp

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=

